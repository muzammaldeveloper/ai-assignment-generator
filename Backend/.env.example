# =============================================================
# AI Assignment Generator - Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================

# ── Flask ──
FLASK_APP=app.factory:create_app
FLASK_ENV=development
SECRET_KEY=change-me-to-a-very-long-random-secret-key-minimum-32-chars
DEBUG=true

# ── JWT ──
JWT_SECRET_KEY=change-me-jwt-secret-key-minimum-32-characters-long
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Database ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_assignment_db

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Groq ──
GROQ_API_KEY=gsk-your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096
GROQ_TEMPERATURE=0.7

# ── Google Gemini ──
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-exp

# ── Tavily (Web Research) ──
TAVILY_API_KEY=tvly-your-tavily-api-key
TAVILY_MAX_RESULTS=5

# ── AWS S3 (Production Storage) ──
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=ai-assignment-generator
AWS_S3_REGION=us-east-1

# ── Rate Limiting ──
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_GENERATION=10/hour

# ── Application ──
MAX_CONCURRENT_JOBS=10
ASSIGNMENT_TIMEOUT_SECONDS=120
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=storage